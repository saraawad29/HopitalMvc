@model HopitalMvcSqlite.Models.Patient

<h1>Modifier Patient</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Phone"></label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="DateOfBirth"></label>
        <input asp-for="DateOfBirth" type="date" class="form-control" />
    </div>

    <div class="mb-3">
    <label asp-for="FileNumber" class="form-label"></label>
    <input asp-for="FileNumber" class="form-control" />
    <span asp-validation-for="FileNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
    <label asp-for="Address.Street"></label>
    <input asp-for="Address.Street" class="form-control" />
    <span asp-validation-for="Address.Street" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address.City"></label>
        <input asp-for="Address.City" class="form-control" />
        <span asp-validation-for="Address.City" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address.PostalCode"></label>
        <input asp-for="Address.PostalCode" class="form-control" />
        <span asp-validation-for="Address.PostalCode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address.Country"></label>
        <input asp-for="Address.Country" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="DepartmentId">Département</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
</form>