@model IEnumerable<HopitalMvcSqlite.Models.Consultation>

<h1>Consultations du jour - Dr @ViewBag.Doctor?.LastName @ViewBag.Doctor?.FirstName</h1>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Patient</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
@foreach (var c in Model)
{
        <tr>
            <td>@c.Date</td>
            <td>@c.Patient?.LastName</td>
            <td>@c.Status</td>
        </tr>
}
    </tbody>
</table>